{
  "name": "hotel-app",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "docker:up": "docker compose --env-file .dev.env up --build",
    "docker:down": "docker compose --env-file .dev.env down",
    "docker:watch": "docker compose --env-file .dev.env watch",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^26.0.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1075.0",
    "@aws-sdk/client-s3": "3.1077.0",
    "@aws-sdk/lib-dynamodb": "^3.1075.0",
    "chalk": "^5.6.2",
    "express": "^5.2.1"
  }
}
