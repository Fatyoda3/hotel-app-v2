{
  "name": "hotel-app",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "docker:up": "docker compose --env-file .dev.env up --build",
    "docker:down": "docker compose --env-file .dev.env down",
    "docker:watch": "docker compose --env-file .dev.env watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watchAll",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "dev": "tsx watch --env-file=.dev.env src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1075.0",
    "@aws-sdk/client-s3": "3.1077.0",
    "@aws-sdk/lib-dynamodb": "^3.1075.0",
    "bcrypt": "^6.0.0",
    "chalk": "^5.6.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.0"
  }
}
